# File: .env
# Purpose: Configuration of secret keys and system specific environment variables.
# Usage: Loaded by env.config.js for application wide availability.

PORT=3000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/medclear
JWT_SECRET=YOUR_SUPER_SECRET_JWT_KEY
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
PYTHON_OCR_SERVICE_URL=http://localhost:8000
NODE_ENV=development
